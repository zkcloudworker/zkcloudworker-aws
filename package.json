{
  "name": "zkcloudworker-aws",
  "description": "zkCloudWorker AWS",
  "keywords": [
    "zkCloudWorker",
    "backend",
    "cloud",
    "proof",
    "mina",
    "zkapp",
    "zk",
    "blockchain",
    "web3",
    "zero knowledge"
  ],
  "version": "0.5.0",
  "author": "DFST",
  "license": "Apache-2.0",
  "type": "module",
  "scripts": {
    "deploy": "serverless deploy --aws-profile zkcloudworker",
    "prune": "serverless prune --aws-profile zkcloudworker -n 5",
    "build": "serverless package --aws-profile zkcloudworker",
    "info": "serverless info --aws-profile zkcloudworker",
    "org": "serverless --org=dfstio --aws-profile zkcloudworker",
    "profile": "serverless config credentials --provider aws --key ACCESS_KEY --secret SECRET_KEY --profile zkcloudworker --overwrite "
  },
  "devDependencies": {
    "@digitalmaas/serverless-plugin-lambda-dead-letter": "^1.0.0",
    "@types/adm-zip": "^0.5.7",
    "@types/aws-lambda": "^8.10.156",
    "@types/node": "^24.9.1",
    "esbuild": "^0.25.11",
    "serverless": "^4.22.0",
    "serverless-iam-roles-per-function": "^3.2.0",
    "serverless-prune-plugin": "^2.1.0",
    "typescript": "^5.9.3"
  },
  "dependencies": {
    "@aws-sdk/client-cloudwatch-logs": "^3.916.0",
    "@aws-sdk/client-dynamodb": "^3.916.0",
    "@aws-sdk/client-kms": "^3.916.0",
    "@aws-sdk/client-lambda": "^3.916.0",
    "@aws-sdk/client-lightsail": "^3.916.0",
    "@aws-sdk/client-s3": "^3.916.0",
    "@aws-sdk/s3-request-presigner": "^3.916.0",
    "@aws-sdk/util-dynamodb": "^3.916.0",
    "@nats-io/jetstream": "^3.2.0",
    "@nats-io/kv": "^3.2.0",
    "@nats-io/transport-node": "^3.2.0",
    "@silvana-one/api": "^1.1.4",
    "@silvana-one/prover": "^1.1.4",
    "adm-zip": "^0.5.16",
    "algoliasearch": "^5.41.0",
    "axios": "^1.12.2",
    "dotenv": "^17.2.3",
    "jose": "^6.1.0",
    "rate-limiter-flexible": "^7.4.0"
  },
  "packageManager": "yarn@4.10.3"
}
